# Copy to .env at repo root. NEVER commit .env.

# ── Mode ────────────────────────────────────────────────
# LIVE_TRADING must stay false until Promotion Gates A–C pass (MVP §12, §15).
LIVE_TRADING=false
ENVIRONMENT=development

# Run the trading worker inside the API process (single-process local dev;
# scripts/run_local.py sets this for you). Keep false in Docker — the worker
# is its own container there.
WORKER_EMBEDDED=false

# Optional full SQLAlchemy URL override. Leave empty to derive automatically:
# Postgres when POSTGRES_PASSWORD is set, otherwise a local SQLite file
# (data/algotrader.db) for zero-setup development.
DATABASE_URL=

# ── Database ────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=algotrader
POSTGRES_USER=algotrader
POSTGRES_PASSWORD=change_me

# ── Redis ───────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Alpaca (separate paper/live credentials, MVP §15) ──
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET=
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET=

# ── Notifications ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI Analyst (optional, read-only, off by default) ───
AI_ANALYST_ENABLED=false
ANTHROPIC_API_KEY=

# ── Dashboard auth ─────────────────────────────────────
JWT_SECRET=change_me_long_random
